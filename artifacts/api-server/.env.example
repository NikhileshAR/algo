# ── Required ─────────────────────────────────────────────────────────────────
PORT=3000

# ── AI Provider ──────────────────────────────────────────────────────────────
# Options: openrouter (default) | gemini | ollama
AI_PROVIDER=openrouter

# OpenRouter (default provider) — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Optional: override the model (default: meta-llama/llama-3.3-70b-instruct:free)
# OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Gemini (only if AI_PROVIDER=gemini) ─────────────────────────────────────
# GEMINI_API_KEY=your-key-here
# GEMINI_MODEL=gemini-1.5-flash

# ── Ollama (only if AI_PROVIDER=ollama) ──────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
